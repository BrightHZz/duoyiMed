# My AI Writer — 本地化配置文件
# 复制此文件为 .env 并修改路径: cp .env.example .env

# === 项目根目录 (必填) ===
MAW_PROJECT_ROOT=~/Documents/trae_projects/my-ai-writer

# === Obsidian 知识库父目录 ===
# laoNianYiXue/ 和 miNiaoWaiKe/ 应在此目录下
MAW_OBSIDIAN_HOME=~/Documents/trae_projects/obsidian

# === 数据文件父目录 ===
MAW_DATA_HOME=~/Documents/trae_projects/dataset

# === 各数据源路径 (可选, 默认从 MAW_DATA_HOME 推断) ===
# CHARLS_DATA_DIR=
# CLHLS_DATA_DIR=
# MIMIC_DATA_DIR=
# SEER_DATA_DIR=

# === LLM 配置 ===
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# 如果使用 DeepSeek:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
